---
import { STATUS_TAILWIND, EPISTEMIC_TAILWIND, STATUS_LABEL } from '../lib/status';

type Claim = {
  slug: string;
  claim: string;
  displayClaim?: string;
  panel?: string;
  status: string;
  epistemic: string;
  isAssessment?: boolean;
  requires?: string[];
  figureUrl?: string | null;
};

type Props = {
  claim: Claim;
  depth: number;
  paperSlug: string;
  baseUrl: string;
  allClaims: Record<string, Claim>;
  tier?: 'primary' | 'secondary';
  foldable?: boolean;
};

const { claim, depth, paperSlug, baseUrl, allClaims, tier = 'primary', foldable = false } = Astro.props as Props;
const url = (path: string) => `${baseUrl}${path}/`;

const children = (claim.requires ?? [])
  .map(s => allClaims[s])
  .filter(Boolean) as Claim[];

const claimText = claim.displayClaim?.trim() || claim.claim;

// Visual scale: roots big, then progressively smaller, floor at depth 3+
const isRoot = depth === 0;
const isSecondaryRoot = isRoot && tier === 'secondary';
const cardPad = isSecondaryRoot ? 'p-4 md:p-5' : isRoot ? 'p-5 md:p-6' : depth === 1 ? 'p-4' : 'p-3';
const titleSize = isSecondaryRoot
  ? 'text-base leading-snug'
  : isRoot ? 'text-lg leading-snug' : depth === 1 ? 'text-base leading-snug' : 'text-sm leading-snug';
const cardBg = isSecondaryRoot
  ? 'bg-gray-50/60 border border-gray-200 hover:border-gray-400 hover:bg-gray-50'
  : isRoot
    ? 'bg-white border-2 border-gray-300 shadow-sm hover:border-blue-400 hover:shadow-md'
    : 'bg-white border border-gray-200 hover:border-gray-400 hover:bg-gray-50';
---

<div class={isRoot ? 'mb-10' : 'mt-3'} id={`claim-card-${claim.slug}`} data-claim-slug={claim.slug}>
  <a
    href={url(`/papers/${paperSlug}/${claim.slug}`)}
    class={`block ${cardPad} rounded-lg no-underline transition-all group ${cardBg}`}
  >
    <div class="flex items-start gap-3">
      <div class="flex-1 min-w-0">
        {claim.panel && (
          <div class="text-xs text-gray-500 uppercase tracking-wider mb-1.5 font-medium">
            {claim.panel}
          </div>
        )}
        <p class={`${titleSize} text-gray-900 font-normal mb-2`}>
          {claimText}
        </p>
        <div class="flex items-center gap-2 flex-wrap mt-2">
          <span class={`text-xs px-1.5 py-0.5 rounded ${STATUS_TAILWIND[claim.status] ?? 'bg-gray-50 text-gray-500'}`}>
            {STATUS_LABEL[claim.status] ?? claim.status}
          </span>
          <span class={`text-xs px-1.5 py-0.5 rounded ${EPISTEMIC_TAILWIND[claim.epistemic] ?? 'bg-gray-50 text-gray-500'}`}>
            {claim.epistemic}
          </span>
          {claim.isAssessment && (
            <span class="text-xs text-purple-600 bg-purple-50 px-1.5 py-0.5 rounded">assessment</span>
          )}
          <span class="text-xs text-gray-400 ml-auto font-mono">{claim.slug}</span>
        </div>
      </div>
    </div>
  </a>

  {claim.figureUrl && (
    <details class="claim-figure mt-2 ml-1">
      <summary class="claim-figure-summary text-xs text-gray-500 hover:text-gray-700 cursor-pointer select-none py-1 pl-1">
        <span class="claim-figure-chevron">▸</span>
        <span class="ml-1">Show figure{claim.panel ? ` (${claim.panel})` : ''}</span>
      </summary>
      <a href={claim.figureUrl} target="_blank" rel="noopener" class="block mt-2">
        <img
          src={claim.figureUrl}
          alt={`Figure for ${claim.slug}${claim.panel ? ` (${claim.panel})` : ''}`}
          loading="lazy"
          class="claim-figure-img rounded border border-gray-200 bg-white"
        />
      </a>
    </details>
  )}

  {children.length > 0 && (foldable ? (
    <details class="claim-fold mt-2">
      <summary class="claim-fold-summary text-xs text-gray-500 hover:text-gray-700 cursor-pointer select-none py-1 pl-1">
        <span class="claim-fold-chevron">▸</span>
        <span class="ml-1">Supporting claims ({children.length})</span>
      </summary>
      <div class="mt-2 ml-6 pl-4 border-l-2 border-gray-200">
        {children.map(child => (
          <Astro.self
            claim={child}
            depth={depth + 1}
            paperSlug={paperSlug}
            baseUrl={baseUrl}
            allClaims={allClaims}
            foldable={foldable}
          />
        ))}
      </div>
    </details>
  ) : (
    <div class="mt-3 ml-6 pl-4 border-l-2 border-gray-200">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
        {isRoot ? 'Supporting claims' : 'Supports'}
      </div>
      {children.map(child => (
        <Astro.self
          claim={child}
          depth={depth + 1}
          paperSlug={paperSlug}
          baseUrl={baseUrl}
          allClaims={allClaims}
        />
      ))}
    </div>
  ))}
</div>

<style>
  details.claim-fold > summary {
    list-style: none;
  }
  details.claim-fold > summary::-webkit-details-marker {
    display: none;
  }
  details.claim-fold > summary .claim-fold-chevron {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  details.claim-fold[open] > summary .claim-fold-chevron {
    transform: rotate(90deg);
  }
  details.claim-figure > summary {
    list-style: none;
  }
  details.claim-figure > summary::-webkit-details-marker {
    display: none;
  }
  details.claim-figure > summary .claim-figure-chevron {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  details.claim-figure[open] > summary .claim-figure-chevron {
    transform: rotate(90deg);
  }
  .claim-figure-img {
    max-width: 100%;
    max-height: 400px;
    height: auto;
    display: block;
  }
</style>
