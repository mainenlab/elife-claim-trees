---
import { STATUS_LABEL } from '../lib/status';

type Claim = {
  slug: string;
  claim: string;
  displayClaim?: string | null;
  panel?: string;
  status: string;
  epistemic: string;
  role?: string | null;
  isAssessment?: boolean;
  requires?: string[];
  figureUrl?: string | null;
  script?: string | null;
  original_script?: string | null;
  script_execution?: string | null;
  script_execution_note?: string | null;
  notes?: string | null;
  time_fast?: string | null;
  time_full?: string | null;
  number?: string | null;
};

type Props = {
  claim: Claim;
  paperSlug: string;
  allClaims: Record<string, Claim>;
  depth?: number;
  showChildren?: boolean;
};

const { claim, paperSlug, allClaims, depth = 0, showChildren = true } = Astro.props as Props;

// Role chip palette — desaturated ~15% compared to ClaimStructure (e.g. 400/500 weights)
const roleStyle: Record<string, string> = {
  hypothesis:     'bg-violet-50 text-violet-700 border-violet-200',
  prediction:     'bg-indigo-50 text-indigo-700 border-indigo-200',
  empirical:      'bg-sky-50 text-sky-700 border-sky-200',
  control:        'bg-emerald-50 text-emerald-700 border-emerald-200',
  interpretation: 'bg-amber-50 text-amber-700 border-amber-200',
  synthesis:      'bg-rose-50 text-rose-700 border-rose-200',
  methodological: 'bg-teal-50 text-teal-700 border-teal-200',
  scope:          'bg-slate-50 text-slate-600 border-slate-200',
};

// Status dot color — simplified palette
function statusDot(status: string): { color: string; label: string } {
  if (status === 'verified') return { color: '#22c55e', label: STATUS_LABEL[status] ?? status };
  if (status === 'failed' || status?.startsWith('unverified:code-error') || status?.startsWith('unverified:compute-infeasible')) {
    return { color: '#f59e0b', label: STATUS_LABEL[status] ?? status };
  }
  return { color: '#9ca3af', label: STATUS_LABEL[status] ?? status ?? 'unknown' };
}

const dot = statusDot(claim.status);
const claimText = (claim.displayClaim?.trim()) || claim.claim;
const hasCode = !!claim.script;
const hasFigure = !!claim.figureUrl;
const isVerified = claim.status.startsWith('verified');

// Recursive children (requires) for supporting-claims disclosure
const children = (claim.requires ?? [])
  .map(s => allClaims[s])
  .filter(Boolean) as Claim[];
---

<div
  class="claim-mini"
  data-claim-slug={claim.slug}
  id={`claim-card-${claim.slug}`}
>
  <div class={`claim-mini-card ${isVerified ? 'claim-mini-verified' : ''}`} data-claim-slug={claim.slug} tabindex="0" role="button" aria-label={`Open details for ${claim.slug}`}>
    {/* Top row: number + role chip + panel ref + status dot + code/figure glyphs */}
    <div class="claim-mini-top">
      {claim.number && (
        <span class="mini-number">{claim.number}</span>
      )}
      {claim.role && (
        <span class={`mini-role-chip ${roleStyle[claim.role] ?? roleStyle.empirical}`}>
          {claim.role.toUpperCase()}
        </span>
      )}
      {claim.panel && claim.panel.toLowerCase() !== (claim.role ?? '').toLowerCase() && (
        <span class="mini-panel">{claim.panel}</span>
      )}
      <span
        class="mini-status-dot"
        style={`background:${dot.color}`}
        title={dot.label}
        aria-label={`Status: ${dot.label}`}
      />
      {isVerified && (
        <span class="mini-verified-badge" title="Verified" aria-label="Verified">✓ verified</span>
      )}
      {!isVerified && hasCode && (
        <span class="mini-code-badge" title="Has verification code" aria-label="Has verification code">{ } code</span>
      )}
    </div>

    {/* Body: one sentence */}
    <p class="claim-mini-body">{claimText}</p>
  </div>

  {/* Disclosures — outside the clickable card surface (stopPropagation on clicks) */}
  <div class="claim-mini-disclosures">
    {showChildren && children.length > 0 && (
      <details class="mini-disclosure mini-children-disclosure">
        <summary class="mini-disclosure-summary">
          <span class="mini-chev">▸</span>
          <span class="ml-1">Supporting claims ({children.length})</span>
        </summary>
        <div class="mini-children-wrap">
          {children.map(child => (
            <Astro.self
              claim={child}
              paperSlug={paperSlug}
              allClaims={allClaims}
              depth={depth + 1}
            />
          ))}
        </div>
      </details>
    )}
  </div>
</div>

<style>
  .claim-mini {
    margin: 0 0 0.55rem 0;
    max-width: 640px;
  }
  .claim-mini-card {
    cursor: pointer;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    background: #fff;
    transition: border-color 0.12s ease, box-shadow 0.12s ease, background-color 0.12s ease;
    outline: none;
  }
  .claim-mini-verified {
    border-left: 3px solid #22c55e;
  }
  .claim-mini-card:hover,
  .claim-mini-card:focus-visible {
    border-color: #9ca3af;
    background: #fafafa;
  }
  .claim-mini-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.72rem;
    margin-bottom: 0.4rem;
  }
  .mini-number {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    color: #888;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .mini-role-chip {
    display: inline-block;
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 1px 6px;
    border-radius: 3px;
    border: 1px solid;
    text-transform: uppercase;
  }
  .mini-panel {
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 10px;
    font-variant: small-caps;
  }
  .mini-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    display: inline-block;
    flex-shrink: 0;
  }
  .mini-verified-badge {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9.5px;
    font-weight: 600;
    color: #166534;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    padding: 0px 5px;
    border-radius: 3px;
    letter-spacing: 0.02em;
  }
  .mini-code-badge {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 9.5px;
    color: #6b7280;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    padding: 0px 5px;
    border-radius: 3px;
    letter-spacing: -0.02em;
  }
  .mini-figure-glyph {
    font-size: 11px;
    color: #94a3b8;
    line-height: 1;
  }
  .claim-mini-body {
    font-size: 1rem; /* ~16px; spec said ~18pt but that's large for body density */
    line-height: 1.55;
    color: #111827;
    margin: 0;
    font-weight: 400;
  }

  .claim-mini-disclosures {
    padding: 0.25rem 0 0 0.5rem;
  }
  .mini-disclosure {
    margin-top: 0.2rem;
  }
  .mini-disclosure > summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    color: #6b7280;
    font-size: 0.72rem;
    padding: 0.2rem 0.25rem;
    border-radius: 3px;
  }
  .mini-disclosure > summary:hover {
    color: #374151;
    background: #f9fafb;
  }
  .mini-disclosure > summary::-webkit-details-marker { display: none; }
  .mini-disclosure .mini-chev {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .mini-disclosure[open] > summary .mini-chev {
    transform: rotate(90deg);
  }

  .mini-children-wrap {
    margin-top: 0.4rem;
    padding-left: 1rem;
    border-left: 2px solid #e5e7eb;
  }

  :global(.claim-card-highlight) {
    outline: 3px solid #fbbf24 !important;
    outline-offset: 4px;
    transition: outline-color 0.4s ease;
  }
</style>

<script>
  // Dispatch open-claim events when the card body is clicked (not its disclosures / inner links).
  document.querySelectorAll<HTMLElement>('.claim-mini-card').forEach(card => {
    const slug = card.dataset.claimSlug;
    if (!slug) return;
    const activate = (e: Event) => {
      // Guard against triggering through bubbling from disclosures/links.
      const target = e.target as HTMLElement;
      if (target.closest('.mini-disclosure')) return;
      if (target.closest('a')) return;
      e.preventDefault();
      window.dispatchEvent(new CustomEvent('open-claim', { detail: { slug } }));
    };
    card.addEventListener('click', activate);
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        activate(e);
      }
    });
  });
</script>
