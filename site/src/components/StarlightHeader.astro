---
// Custom Starlight header — matches the existing site's nav (Layout.astro).
// Starlight's default Header renders title + search + theme toggle. We
// replace it with the same sticky 12px-tall nav the rest of the site uses,
// plus the search and theme toggle off to the right.

import Search from '@astrojs/starlight/components/Search.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}/`;

// Active-link highlighting based on the current path.
const pathname = Astro.url.pathname.replace(base, '') || '/';
const isActive = (path: string) =>
  path === '/'
    ? pathname === '/' || pathname === ''
    : pathname.startsWith(path);
---

<div class="site-nav-wrapper">
  <nav class="site-nav">
    <div class="site-nav-inner">
      <a href={url('')} class="site-brand">Claims</a>
      <a href={url('/papers')} class={`site-nav-link site-nav-desktop ${isActive('/papers') ? 'active' : ''}`}>Papers</a>
      <a href={url('/methodology')} class={`site-nav-link site-nav-desktop ${isActive('/methodology') ? 'active' : ''}`}>Methodology</a>
      <a href={url('/findings')} class={`site-nav-link site-nav-desktop ${isActive('/findings') ? 'active' : ''}`}>Findings</a>
      <a href={url('/docs')} class={`site-nav-link site-nav-desktop ${isActive('/docs') ? 'active' : ''}`}>Docs</a>
      <a href={url('/standards')} class={`site-nav-link site-nav-desktop ${isActive('/standards') ? 'active' : ''}`}>Standards</a>
      <a href={url('/extract')} class={`site-nav-link site-nav-desktop ${isActive('/extract') ? 'active' : ''}`}>Extract</a>
      <div class="site-nav-spacer"></div>
      <div class="site-nav-actions">
        <Search {...Astro.props} />
        <SocialIcons {...Astro.props} />
        <ThemeSelect {...Astro.props} />
      </div>
    </div>
  </nav>
</div>

<style>
  .site-nav-wrapper {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #ffffff;
    border-bottom: 1px solid #f3f4f6;
  }

  .site-nav {
    width: 100%;
  }

  .site-nav-inner {
    max-width: 80rem;            /* matches max-w-7xl */
    margin: 0 auto;
    padding: 0 1rem;
    height: 3rem;                 /* matches h-12 */
    display: flex;
    align-items: center;
    gap: 1.5rem;                  /* matches gap-6 */
    font-family: Inter, system-ui, -apple-system, sans-serif;
  }

  .site-brand {
    font-weight: 600;
    font-size: 0.875rem;          /* text-sm */
    color: #111827;               /* gray-900 */
    text-decoration: none;
  }

  .site-brand:hover {
    color: #374151;               /* gray-700 */
  }

  .site-nav-link {
    font-size: 0.875rem;
    color: #6b7280;               /* gray-500 */
    text-decoration: none;
  }

  .site-nav-link:hover {
    color: #374151;               /* gray-700 */
  }

  .site-nav-link.active {
    color: #111827;
    font-weight: 500;
  }

  .site-nav-spacer {
    flex: 1;
  }

  @media (max-width: 768px) {
    .site-nav-desktop {
      display: none;
    }
  }

  .site-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
  }

  /* Make the Starlight search button look minimal and match the nav text */
  .site-nav-actions :global(button) {
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    padding: 4px 8px;
    background: #ffffff;
    color: #6b7280;
    font-size: 0.75rem;
    font-family: Inter, system-ui, -apple-system, sans-serif;
    cursor: pointer;
  }

  .site-nav-actions :global(button:hover) {
    background: #f9fafb;
    color: #111827;
  }

  /* Dark mode */
  :root[data-theme='dark'] .site-nav-wrapper {
    background: #0f0f0f;
    border-bottom-color: #1f2937;
  }
  :root[data-theme='dark'] .site-brand {
    color: #f3f4f6;
  }
  :root[data-theme='dark'] .site-brand:hover {
    color: #d1d5db;
  }
  :root[data-theme='dark'] .site-nav-link {
    color: #9ca3af;
  }
  :root[data-theme='dark'] .site-nav-link:hover {
    color: #d1d5db;
  }
  :root[data-theme='dark'] .site-nav-link.active {
    color: #f3f4f6;
  }
  :root[data-theme='dark'] .site-nav-actions :global(button) {
    border-color: #374151;
    background: #0f0f0f;
    color: #9ca3af;
  }
  :root[data-theme='dark'] .site-nav-actions :global(button:hover) {
    background: #1a1a1a;
    color: #f3f4f6;
  }
</style>
