---
import ClaimCardMini from './ClaimCardMini.astro';

type Claim = {
  slug: string;
  claim: string;
  displayClaim?: string;
  shortClaim?: string | null;
  panel?: string;
  status: string;
  epistemic: string;
  isAssessment?: boolean;
  requires?: string[];
  figureUrl?: string | null;
  role?: string | null;
  scopes?: string[];
  'enables-method'?: string[];
  entails?: string[];
  tests?: string[];
  supports?: string[];
  refutes?: string[];
  'dissociates-with'?: string[];
  'rules-out'?: string[];
  validates?: string[];
  interprets?: string[];
  'derived-from'?: string[];
  number?: string | null;
};

type Props = {
  paper: { slug: string; claims: Claim[] };
  paperSlug: string;
  baseUrl: string;
  claimsBySlug: Record<string, Claim>;
};

const { paper, paperSlug, baseUrl, claimsBySlug } = Astro.props as Props;

const all = paper.claims;
const byRole = (r: string) => all.filter(c => c.role === r);

const scopeStar = byRole('scope').filter(c => (c.scopes ?? []).includes('*'));
const scopeTargeted = byRole('scope').filter(c => {
  const s = c.scopes ?? [];
  return s.length > 0 && !s.includes('*');
});
const methodological = byRole('methodological');
const hypotheses = byRole('hypothesis');
const interpretations = byRole('interpretation');
const synthesis = byRole('synthesis');
const empirical = byRole('empirical');
const controls = byRole('control').filter(c => (c['rules-out']?.length ?? 0) > 0 || (c.validates?.length ?? 0) > 0);

// Dissociation pairs — de-duplicated
type Pair = { a: Claim; b: Claim; key: string };
const dissocPairs: Pair[] = [];
const seen = new Set<string>();
for (const c of all) {
  for (const otherSlug of (c['dissociates-with'] ?? [])) {
    const other = claimsBySlug[otherSlug];
    if (!other) continue;
    const key = [c.slug, otherSlug].sort().join('|');
    if (seen.has(key)) continue;
    seen.add(key);
    dissocPairs.push({ a: c, b: other, key });
  }
}
const dissocSlugs = new Set<string>();
dissocPairs.forEach(p => { dissocSlugs.add(p.a.slug); dissocSlugs.add(p.b.slug); });

// Standalone empirical: role:empirical, no `tests`, not in any dissociation pair
const standaloneEmpirical = empirical.filter(c =>
  (c.tests?.length ?? 0) === 0 && !dissocSlugs.has(c.slug)
);

// Helper: which claims have `tests` pointing at a given prediction/hypothesis slug?
const testsOf = (targetSlug: string): Claim[] =>
  all.filter(c => (c.tests ?? []).includes(targetSlug));

// ---------- SUMMARY BOX ----------
// Figure count: distinct non-methods figure numbers (e.g. "Fig 4a" + "Fig 4b" → one "Fig 4").
const figureSet = new Set<string>();
for (const c of all) {
  const pnl = c.panel;
  if (!pnl) continue;
  for (const part of pnl.split(/[,;]/)) {
    const p = part.trim().toLowerCase();
    if (!p || p.includes('method')) continue;
    const m = p.match(/(?:fig(?:ure)?)\s*0*(\d+)/);
    if (m) figureSet.add(m[1]);
  }
}
const figureCount = figureSet.size;

const metaParts: string[] = [];
if (hypotheses.length) metaParts.push(`${hypotheses.length} hypothes${hypotheses.length === 1 ? 'is' : 'es'} tested`);
if (empirical.length) metaParts.push(`${empirical.length} empirical claim${empirical.length === 1 ? '' : 's'}`);
if (figureCount) metaParts.push(`${figureCount} figure${figureCount === 1 ? '' : 's'}`);
if (controls.length) metaParts.push(`${controls.length} control${controls.length === 1 ? '' : 's'}`);
if (synthesis.length) metaParts.push(`${synthesis.length} synthesis claim${synthesis.length === 1 ? '' : 's'}`);

// Refuted hypotheses: any claim in this paper with `refutes` pointing at a hypothesis slug here.
const hypothesisSlugs = new Set(hypotheses.map(h => h.slug));
const refutedHypothesisSlugs = new Set<string>();
for (const c of all) {
  for (const tgt of (c.refutes ?? [])) {
    if (hypothesisSlugs.has(tgt)) refutedHypothesisSlugs.add(tgt);
  }
}
const refutedHypotheses = hypotheses.filter(h => refutedHypothesisSlugs.has(h.slug));

// Presents substitute (atlas/descriptive): when no hypotheses, show top empirical claims by epistemic rank then file order.
const epistemicRank: Record<string, number> = { strong: 3, moderate: 2, weak: 1 };
const presentsClaims: Claim[] = hypotheses.length === 0
  ? [...empirical]
      .map((c, i) => ({ c, i }))
      .sort((a, b) =>
        ((epistemicRank[b.c.epistemic ?? ''] ?? 0) - (epistemicRank[a.c.epistemic ?? ''] ?? 0))
        || (a.i - b.i)
      )
      .slice(0, 4)
      .map(x => x.c)
  : [];

function bulletText(c: Claim): string {
  return (c.shortClaim?.trim()) || (c.displayClaim?.trim()) || c.claim || '';
}

// A summary bullet is either a claim rendered normally, or a refuted-hypothesis
// bullet whose text is the hypothesis shortClaim with " — not supported" appended.
// Both dispatch `open-claim` with the backing claim's slug.
type SummaryItem = { claim: Claim; text: string };
function itemOf(c: Claim): SummaryItem {
  return { claim: c, text: bulletText(c) };
}
function refutationItemOf(h: Claim): SummaryItem {
  const short = bulletText(h).replace(/\s+$/, '').replace(/[.]+$/, '');
  return { claim: h, text: `${short} — not supported` };
}

type SummaryLine = { label: string; items: SummaryItem[] };
const summaryLines: SummaryLine[] = [];
if (hypotheses.length > 0) {
  // TESTS includes every hypothesis the paper tested — outcome is separate.
  summaryLines.push({ label: 'Tests', items: hypotheses.map(itemOf) });
} else if (presentsClaims.length > 0) {
  summaryLines.push({ label: 'Presents', items: presentsClaims.map(itemOf) });
}
if (synthesis.length > 0) summaryLines.push({ label: 'Finds', items: synthesis.map(itemOf) });
// IMPLIES combines interpretation-role claims with refutation bullets.
const impliesItems: SummaryItem[] = [
  ...interpretations.map(itemOf),
  ...refutedHypotheses.map(refutationItemOf),
];
if (impliesItems.length > 0) summaryLines.push({ label: 'Implies', items: impliesItems });

// Render bullets inline (comma-separated) when every item text fits under ~40 chars; otherwise vertical list.
const INLINE_THRESHOLD = 40;
function useInline(items: SummaryItem[]): boolean {
  return items.every(it => it.text.length <= INLINE_THRESHOLD);
}

const showSummary = metaParts.length > 0 || summaryLines.length > 0;
---

<section class="mb-6 claims-section-root">
  <div class="claims-section-toolbar">
    <h2 class="text-base font-semibold text-gray-900 uppercase tracking-wide m-0">
      Logic of the Claims
    </h2>
    <button type="button" class="toggle-all-btn" data-state="collapsed" aria-label="Expand or collapse all sections">Expand all</button>
  </div>

  {showSummary && (
    <details class="summary-details mb-4" open>
      <summary class="summary-details-summary cursor-pointer select-none">
        <span class="summary-details-chevron mr-1 text-gray-400">▸</span>
        <span class="summary-heading">Summary</span>
      </summary>
      <div class="summary-box-body">
        {summaryLines.map(line => {
          const isImplies = line.label === 'Implies';
          return (
          <div class="summary-line">
            <span class="summary-line-label">{line.label.toUpperCase()} —</span>
            {useInline(line.items) ? (
              <span class="summary-line-inline">
                {line.items.map((it, i) => {
                  // Suppress the number prefix for refutation bullets inside IMPLIES,
                  // since the hypothesis number already appears in the TESTS line above.
                  const isRefutation = isImplies && it.text.endsWith('not supported');
                  const showNumber = !!it.claim.number && !isRefutation;
                  return (
                  <Fragment>
                    {i > 0 && <span class="summary-inline-sep">, </span>}
                    <button type="button" class="summary-bullet-inline" data-claim-slug={it.claim.slug}>
                      {showNumber && <span class="summary-bullet-number">{it.claim.number}:</span>}
                      {showNumber ? ' ' : ''}{it.text}
                    </button>
                  </Fragment>
                  );
                })}
              </span>
            ) : (
              <ul class="summary-list">
                {line.items.map(it => {
                  const isRefutation = isImplies && it.text.endsWith('not supported');
                  const showNumber = !!it.claim.number && !isRefutation;
                  return (
                  <li>
                    <button type="button" class="summary-bullet" data-claim-slug={it.claim.slug}>
                      {showNumber && <span class="summary-bullet-number">{it.claim.number}:</span>}
                      {showNumber ? ' ' : ''}{it.text}
                    </button>
                  </li>
                  );
                })}
              </ul>
            )}
          </div>
          );
        })}
        {metaParts.length > 0 && (
          <div class="summary-meta-footer">{metaParts.join(' · ')}</div>
        )}
      </div>
    </details>
  )}

  {/* HYPOTHESES AND THEIR TESTS */}
  {hypotheses.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Each hypothesis entails predictions; each prediction is tested by empirical observations that support or refute it. Where a hypothesis entails an empirical claim directly, the prediction layer is implicit.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Hypotheses tested
        </h3>
      </summary>
      <div class="space-y-3 claim-section-body">
        {hypotheses.map(h => {
          const entailed = (h.entails ?? []).map(s => claimsBySlug[s]).filter(Boolean) as Claim[];
          const predictions = entailed.filter(e => e.role === 'prediction');
          const directlyTested = entailed.filter(e => e.role !== 'prediction');
          return (
            <div>
              <ClaimCardMini
                claim={h}
                paperSlug={paperSlug}
                allClaims={claimsBySlug}
                showChildren={false}
              />

              {predictions.length > 0 && (
                <div class="ml-4 pl-4 border-l-2 border-indigo-100">
                  <div class="text-[10px] font-semibold text-indigo-600 uppercase tracking-wider mb-2 mt-1">Predictions entailed</div>
                  {predictions.map(p => {
                    const tests = testsOf(p.slug);
                    return (
                      <div>
                        <ClaimCardMini
                          claim={p}
                          paperSlug={paperSlug}
                          allClaims={claimsBySlug}
                          showChildren={false}
                        />
                        {tests.length > 0 && (
                          <details class="ml-2 pl-3 border-l-2 border-sky-100 mb-3" open={tests.length <= 3}>
                            <summary class="cursor-pointer select-none text-[10px] font-semibold text-sky-600 uppercase tracking-wider py-1">
                              Tested by
                            </summary>
                            <div class="mt-2">
                              {tests.map(t => (
                                <ClaimCardMini
                                  claim={t}
                                  paperSlug={paperSlug}
                                  allClaims={claimsBySlug}
                                  showChildren={false}
                                />
                              ))}
                            </div>
                          </details>
                        )}
                      </div>
                    );
                  })}
                </div>
              )}

              {directlyTested.length > 0 && (
                <div class="ml-4 pl-4 border-l-2 border-sky-100">
                  <div class="text-[10px] font-semibold text-sky-600 uppercase tracking-wider mb-2 mt-1">Tested by</div>
                  {directlyTested.map(t => (
                    <ClaimCardMini
                      claim={t}
                      paperSlug={paperSlug}
                      allClaims={claimsBySlug}
                      showChildren={false}
                    />
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </details>
  )}

  {/* SCOPE banner — qualifies all claims above */}
  {scopeStar.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="All claims above are bounded by the following scope qualifiers.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Scope
        </h3>
      </summary>
      {scopeStar.map(c => (
        <ClaimCardMini
          claim={c}
          paperSlug={paperSlug}
          allClaims={claimsBySlug}
          showChildren={false}
        />
      ))}
    </details>
  )}

  {/* DISSOCIATIONS */}
  {dissocPairs.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Pairs of claims that jointly establish a contrast — the contrast itself is part of the argument.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Dissociations
        </h3>
      </summary>
      <div class="space-y-2 claim-section-body">
        {dissocPairs.map(({ a, b }) => (
          <div class="dissoc-pair">
            <ClaimCardMini claim={a} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
            <div class="dissoc-marker" aria-hidden="true">↔</div>
            <ClaimCardMini claim={b} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
          </div>
        ))}
      </div>
    </details>
  )}

  {/* ELIMINATIONS / CONTROLS */}
  {controls.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Claims that ruled out alternatives or validated other claims via disconfirming controls.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Eliminations &amp; validating controls
        </h3>
      </summary>
      {controls.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}

  {/* INTERPRETATIONS */}
  {interpretations.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Claims that reframe empirical findings through a theoretical lens. These are interpretive moves, not direct measurements.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Interpretations
        </h3>
      </summary>
      {interpretations.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}

  {/* SYNTHESIS */}
  {synthesis.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Claims that combine multiple empirical findings into a single conclusion.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Synthesis claims
        </h3>
      </summary>
      {synthesis.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}

  {/* STANDALONE EMPIRICAL */}
  {standaloneEmpirical.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="Empirical claims that are not parts of an explicit hypothesis-test loop or dissociation.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Standalone empirical findings
        </h3>
      </summary>
      {standaloneEmpirical.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}

  {/* METHODOLOGICAL WARRANTS */}
  {methodological.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="These methodological capabilities enable interpretation of downstream claims.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Methodological warrants
        </h3>
      </summary>
      {methodological.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}

  {/* TARGETED SCOPE QUALIFIERS */}
  {scopeTargeted.length > 0 && (
    <details class="claim-section mb-3">
      <summary class="claim-section-summary cursor-pointer select-none">
        <h3 class="inline text-sm font-semibold text-gray-900 uppercase tracking-wide" data-tooltip="These claims qualify or constrain specific other claims rather than the paper as a whole.">
          <span class="claim-section-chevron mr-1 text-gray-400">▸</span>Scope qualifiers
        </h3>
      </summary>
      {scopeTargeted.map(c => (
        <ClaimCardMini claim={c} paperSlug={paperSlug} allClaims={claimsBySlug} showChildren={false} />
      ))}
    </details>
  )}
</section>

<style>
  /* Hover tooltip on section headings */
  h3[data-tooltip] {
    position: relative;
    cursor: help;
  }
  h3[data-tooltip]::after {
    content: attr(data-tooltip);
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: auto;
    max-width: 500px;
    width: max-content;
    padding: 8px 12px;
    font-size: 13px;
    font-weight: normal;
    line-height: 1.4;
    text-transform: none;
    letter-spacing: normal;
    color: #333;
    background: #FFFCE8;
    border: 1px solid #E6E0B3;
    border-radius: 4px;
    white-space: normal;
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease-out;
    z-index: 50;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  h3[data-tooltip]:hover::after {
    opacity: 1;
  }
  @media (max-width: 640px) {
    h3[data-tooltip]::after {
      max-width: calc(100vw - 2rem);
    }
  }

  details.claim-section > summary {
    list-style: none;
    padding: 0.15rem 0;
  }
  details.claim-section > summary::-webkit-details-marker {
    display: none;
  }
  details.claim-section > summary .claim-section-chevron {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  details.claim-section[open] > summary .claim-section-chevron {
    transform: rotate(90deg);
  }
  /* Section body padding — tightens content inside the details */
  details.claim-section[open] > *:not(summary) {
    padding-top: 0.5rem;
    padding-left: 0.25rem;
  }
  .dissoc-pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: center;
    padding: 0.6rem 0.8rem;
    border: 1px solid #e0f2fe;
    border-radius: 6px;
    background: rgba(240, 249, 255, 0.5);
  }
  .dissoc-marker {
    font-size: 1.25rem;
    color: #0284c7;
    user-select: none;
  }
  @media (max-width: 640px) {
    .dissoc-pair {
      grid-template-columns: 1fr;
    }
    .dissoc-marker { text-align: center; }
  }

  /* ---------- Claims-tab toolbar (heading + expand/collapse) ---------- */
  .claims-section-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .toggle-all-btn {
    background: transparent;
    border: 1px solid transparent;
    padding: 0.2rem 0.5rem;
    margin: 0;
    font: inherit;
    font-size: 11px;
    color: #9ca3af;
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.12s ease, border-color 0.12s ease, background 0.12s ease;
  }
  .toggle-all-btn:hover {
    color: #4b5563;
    border-color: #e5e7eb;
    background: #f9fafb;
  }

  /* ---------- Summary box (now a <details>) ---------- */
  .summary-details {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.6rem 1rem;
  }
  .summary-details > summary {
    list-style: none;
    padding: 0.1rem 0;
  }
  .summary-details > summary::-webkit-details-marker {
    display: none;
  }
  .summary-details-chevron {
    display: inline-block;
    transition: transform 0.15s ease;
  }
  .summary-details[open] > summary .summary-details-chevron {
    transform: rotate(90deg);
  }
  .summary-heading {
    font-size: 0.78rem;
    color: #6b7280;
    line-height: 1.5;
    font-variant: small-caps;
    letter-spacing: 0.05em;
  }
  .summary-box-body {
    margin-top: 0.2rem;
  }
  .summary-line {
    margin-top: 0.55rem;
    line-height: 1.5;
  }
  .summary-line-label {
    display: inline;
    font-variant: small-caps;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: #334155;
    margin-right: 0.4rem;
  }
  .summary-line-inline {
    font-size: 0.88rem;
    color: #374151;
  }
  .summary-inline-sep {
    color: #9ca3af;
  }
  .summary-bullet-inline {
    display: inline;
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: #374151;
    font-size: 0.88rem;
    line-height: 1.45;
    cursor: pointer;
    text-align: left;
    border-bottom: 1px dotted transparent;
    transition: border-color 120ms ease, color 120ms ease;
  }
  .summary-bullet-inline:hover,
  .summary-bullet-inline:focus-visible {
    color: #111827;
    border-bottom-color: #9ca3af;
    outline: none;
  }
  .summary-meta-footer {
    margin-top: 0.75rem;
    padding-top: 0.45rem;
    border-top: 1px solid #f1f5f9;
    font-size: 0.72rem;
    color: #9ca3af;
    line-height: 1.5;
  }
  .summary-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .summary-list li {
    margin: 0;
    padding: 0;
  }
  .summary-bullet {
    display: block;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    padding: 0.22rem 0.35rem 0.22rem 0.9rem;
    margin: 0;
    font: inherit;
    color: #374151;
    font-size: 0.88rem;
    line-height: 1.45;
    cursor: pointer;
    border-radius: 4px;
    position: relative;
  }
  .summary-bullet::before {
    content: '•';
    position: absolute;
    left: 0.2rem;
    top: 0.22rem;
    color: #9ca3af;
  }
  .summary-bullet:hover,
  .summary-bullet:focus-visible {
    background: #f3f4f6;
    color: #111827;
    outline: none;
  }
  .summary-bullet-number {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    color: #6b7280;
    font-weight: 500;
    margin-right: 0.15rem;
  }
</style>

<script>
  // Summary bullets dispatch the same open-claim event that ClaimCardMini uses.
  document.querySelectorAll<HTMLButtonElement>('.summary-bullet, .summary-bullet-inline').forEach(btn => {
    const slug = btn.dataset.claimSlug;
    if (!slug) return;
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent('open-claim', { detail: { slug } }));
    });
  });

  // Expand all / Collapse all — toggles every <details> inside the Claims tab,
  // including the paper-summary details, the role-grouped sections, and the
  // alphabetical-index details at the bottom of the tab.
  function scopedDetails(btn: HTMLButtonElement): HTMLDetailsElement[] {
    const root = btn.closest('.claims-tab-panel') ?? document;
    return Array.from(root.querySelectorAll<HTMLDetailsElement>('details'));
  }
  function updateLabel(btn: HTMLButtonElement) {
    const root = btn.closest('.claims-tab-panel') ?? document;
    const all = Array.from(root.querySelectorAll<HTMLDetailsElement>('details'));
    if (!all.length) return;
    const openCount = all.filter(d => d.open).length;
    const mostlyOpen = openCount > all.length / 2;
    btn.textContent = mostlyOpen ? 'Collapse all' : 'Expand all';
    btn.dataset.state = mostlyOpen ? 'expanded' : 'collapsed';
  }
  document.querySelectorAll<HTMLButtonElement>('.toggle-all-btn').forEach(btn => {
    updateLabel(btn);
    btn.addEventListener('click', () => {
      const all = scopedDetails(btn);
      const shouldExpand = btn.dataset.state !== 'expanded';
      all.forEach(d => { d.open = shouldExpand; });
      updateLabel(btn);
    });
    // Keep label in sync when user toggles individual sections.
    const root = btn.closest('.claims-tab-panel') ?? document;
    root.querySelectorAll<HTMLDetailsElement>('details').forEach(d => {
      d.addEventListener('toggle', () => updateLabel(btn));
    });
  });
</script>
