---
type Tab = { id: string; label: string };

type Props = {
  tabs: Tab[];
  defaultTab?: string;
};

const { tabs, defaultTab = 'structure' } = Astro.props as Props;
---

<nav class="paper-tabs" role="tablist" data-default-tab={defaultTab}>
  {tabs.map(tab => (
    <button
      class="paper-tab"
      role="tab"
      data-tab-id={tab.id}
      aria-selected={tab.id === defaultTab ? 'true' : 'false'}
      tabindex={tab.id === defaultTab ? 0 : -1}
    >
      {tab.label}
    </button>
  ))}
</nav>

<style>
  .paper-tabs {
    display: flex;
    gap: 1.75rem;
    border-bottom: 1px solid #e5e7eb;
    margin-bottom: 2rem;
    padding: 0;
  }
  .paper-tab {
    background: transparent;
    border: none;
    padding: 0.55rem 0 0.75rem;
    margin: 0;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    font-variant: small-caps;
    color: #9ca3af;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.12s ease, border-color 0.12s ease;
    font-family: inherit;
  }
  .paper-tab:hover { color: #4b5563; }
  .paper-tab[aria-selected='true'] {
    color: #269E8C;
    border-bottom-color: #269E8C;
  }
  .paper-tab:focus-visible {
    outline: 2px solid #269E8C;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* The tab panels are rendered outside this component; scoping applies at the
     document level. We mark them with .paper-tab-panel and toggle display. */
  :global(.paper-tab-panel) {
    display: none;
  }
  :global(.paper-tab-panel[data-tab-active='true']) {
    display: block;
  }
</style>

<script>
  const validTabs = new Set<string>();
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.paper-tab'));
  tabButtons.forEach(b => { if (b.dataset.tabId) validTabs.add(b.dataset.tabId); });

  const nav = document.querySelector<HTMLElement>('.paper-tabs');
  const defaultTab = nav?.dataset.defaultTab ?? 'structure';

  function readTab(): string {
    const sp = new URLSearchParams(window.location.search);
    const v = sp.get('view');
    return v && validTabs.has(v) ? v : defaultTab;
  }

  function activate(tabId: string, pushState = true) {
    if (!validTabs.has(tabId)) tabId = defaultTab;
    // Update URL
    if (pushState) {
      const url = new URL(window.location.href);
      if (tabId === defaultTab) url.searchParams.delete('view');
      else url.searchParams.set('view', tabId);
      window.history.pushState({}, '', url.toString());
    }
    // Tab button ARIA states
    tabButtons.forEach(b => {
      const active = b.dataset.tabId === tabId;
      b.setAttribute('aria-selected', active ? 'true' : 'false');
      b.tabIndex = active ? 0 : -1;
    });
    // Panel visibility
    document.querySelectorAll<HTMLElement>('.paper-tab-panel').forEach(p => {
      p.dataset.tabActive = p.dataset.tabId === tabId ? 'true' : 'false';
    });
  }

  // On mount: activate URL-driven tab without pushing state.
  activate(readTab(), false);

  // Button clicks.
  tabButtons.forEach(b => {
    b.addEventListener('click', () => {
      const id = b.dataset.tabId;
      if (!id) return;
      activate(id, true);
    });
  });

  // Browser back/forward syncs.
  window.addEventListener('popstate', () => activate(readTab(), false));
</script>
