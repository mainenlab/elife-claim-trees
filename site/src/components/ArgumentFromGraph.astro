---
type ComparisonRow = {
  kind: 'aligned' | 'reframed' | 'abstract-only' | 'synthesis-only' | string;
  abstractSentence?: string;
  synthesisSentence?: string;
  category?: string;
  note?: string;
};

type TracebackItem = {
  sentence: string;
  claims?: string[];
  relations?: string[];
  move?: string;
};

type SynthesisBlock = {
  synthesizerPrompt?: string;
  synthesis?: string;
  traceback?: TracebackItem[];
  comparatorPrompt?: string;
  comparison?: string;
  comparisonTable?: ComparisonRow[];
  diagnosticDivergence?: string;
  inferentialStructureNote?: string;
};

type Claim = {
  slug: string;
  claim: string;
  displayClaim?: string | null;
  number?: string | null;
};

type Props = {
  synthesis?: SynthesisBlock | null;
  version?: string | null;
  claimsBySlug?: Record<string, Claim>;
  /** @deprecated kept for backward compatibility */
  synthesisV2?: SynthesisBlock | null;
};

const props = Astro.props as Props;
const block = props.synthesis ?? props.synthesisV2 ?? null;
const version = props.version ?? (props.synthesisV2 && !props.synthesis ? 'v2' : null);
const claimsBySlug = props.claimsBySlug ?? {};

// If no synthesis block at all, render nothing.
const hasAny = block && (
  (block.synthesis ?? '').trim() ||
  (block.comparison ?? '').trim() ||
  (block.diagnosticDivergence ?? '').trim() ||
  (block.inferentialStructureNote ?? '').trim() ||
  (block.comparisonTable?.length ?? 0) > 0 ||
  (block.synthesizerPrompt ?? '').trim() ||
  (block.comparatorPrompt ?? '').trim()
);

const synthesis = (block?.synthesis ?? '').trim();
const comparison = (block?.comparison ?? '').trim();
const diagnosticDivergence = (block?.diagnosticDivergence ?? '').trim();
const inferentialStructureNote = (block?.inferentialStructureNote ?? '').trim();
const comparisonTable = block?.comparisonTable ?? [];
const traceback = block?.traceback ?? [];
const synthesizerPrompt = block?.synthesizerPrompt ?? '';
const comparatorPrompt = block?.comparatorPrompt ?? '';

const kindLabel: Record<string, string> = {
  aligned: 'aligned',
  reframed: 'reframed',
  'abstract-only': 'abstract only',
  'synthesis-only': 'synthesis only',
};
---

{hasAny && (
  <section class="mb-12">
    <h2 class="text-base font-semibold text-gray-900 uppercase tracking-wide mb-3 flex items-baseline gap-2">
      <span>Argument from the graph</span>
      {version && (
        <span class="text-[10px] font-medium normal-case tracking-normal text-gray-400 font-mono">{version}</span>
      )}
    </h2>
    <p class="text-sm text-gray-500 italic mb-8 leading-relaxed max-w-3xl">
      An LLM was given only this paper's enriched claim graph — claims, panel references, roles, and the relations between them — with no access to the abstract, paper prose, or any external context. It was asked to reconstruct the argument. Below: the reconstructed argument, then a comparison to the published abstract above. The two prompts that produced these texts are at the bottom, available for inspection.
    </p>

    {synthesis && (
      <div class="mb-8">
        <h3 class="text-base font-semibold text-gray-900 mb-3">Reconstructed argument</h3>
        <p class="text-base leading-relaxed text-gray-900 max-w-3xl whitespace-pre-wrap">{synthesis}</p>
      </div>
    )}

    {(comparison || diagnosticDivergence || inferentialStructureNote) && (
      <div class="mb-8">
        <h3 class="text-base font-semibold text-gray-900 mb-3">Compared to the published abstract</h3>

        {comparison && (
          <p class="text-base leading-relaxed text-gray-900 max-w-3xl whitespace-pre-wrap mb-5">{comparison}</p>
        )}

        {diagnosticDivergence && (
          <div class="max-w-3xl mb-4 border-l-4 border-amber-400 bg-amber-50/60 pl-4 pr-4 py-3 rounded-r-md">
            <div class="text-xs font-semibold text-amber-800 uppercase tracking-wider mb-1">Diagnostic divergence</div>
            <p class="text-sm leading-relaxed text-gray-800 whitespace-pre-wrap">{diagnosticDivergence}</p>
          </div>
        )}

        {inferentialStructureNote && (
          <div class="max-w-3xl mb-4 border-l-4 border-gray-300 bg-gray-50/70 pl-4 pr-4 py-3 rounded-r-md">
            <div class="text-xs font-semibold text-gray-600 uppercase tracking-wider mb-1">On inferential structure recovered</div>
            <p class="text-sm leading-relaxed text-gray-800 whitespace-pre-wrap">{inferentialStructureNote}</p>
          </div>
        )}
      </div>
    )}

    {traceback.length > 0 && (
      <details class="mb-6 rounded-lg border border-gray-200 bg-gray-50/40">
        <summary class="cursor-pointer select-none px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100/60 rounded-t-lg">
          ▸ Show traceback ({traceback.length} synthesis sentence{traceback.length === 1 ? '' : 's'})
        </summary>
        <div class="px-4 pb-4 pt-2">
          <ol class="space-y-3 list-decimal list-inside text-sm">
            {traceback.map(t => (
              <li class="leading-snug">
                <div class="text-gray-800 inline">{t.sentence}</div>
                {(t.claims?.length ?? 0) > 0 && (
                  <div class="mt-1 ml-4 flex flex-wrap gap-x-3 gap-y-1 text-xs">
                    {t.claims!.map(slug => {
                      const c = claimsBySlug[slug];
                      const label = c?.number ?? slug;
                      const preview = c ? (c.displayClaim?.trim() || c.claim || '').slice(0, 80) : '';
                      return (
                        <a
                          href="#"
                          class="traceback-claim inline-flex items-baseline gap-1"
                          data-target-claim={slug}
                        >
                          <span class="font-mono text-gray-600 font-medium">{label}</span>
                          {preview && (
                            <span class="text-gray-500"> · <span class="text-gray-700">{preview}</span></span>
                          )}
                        </a>
                      );
                    })}
                  </div>
                )}
                {t.move && (
                  <div class="mt-0.5 ml-4 text-xs text-gray-500 italic">{t.move}</div>
                )}
              </li>
            ))}
          </ol>
        </div>
      </details>
    )}

    {comparisonTable.length > 0 && (
      <details class="mb-6 rounded-lg border border-gray-200 bg-gray-50/40">
        <summary class="cursor-pointer select-none px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100/60 rounded-t-lg">
          ▸ Show structured comparison table ({comparisonTable.length} rows)
        </summary>
        <div class="overflow-x-auto px-4 pb-4 pt-2">
          <table class="w-full text-xs text-left border-collapse">
            <thead>
              <tr class="border-b border-gray-300 text-gray-500 uppercase tracking-wider">
                <th class="py-2 pr-3 font-medium">Kind</th>
                <th class="py-2 pr-3 font-medium">Abstract sentence</th>
                <th class="py-2 pr-3 font-medium">Synthesis sentence</th>
                <th class="py-2 pr-3 font-medium">Category</th>
                <th class="py-2 font-medium">Note</th>
              </tr>
            </thead>
            <tbody>
              {comparisonTable.map(row => (
                <tr class="border-b border-gray-200 align-top">
                  <td class="py-2 pr-3 whitespace-nowrap">
                    <span class={`inline-block px-1.5 py-0.5 rounded text-[10px] font-medium ${
                      row.kind === 'aligned' ? 'bg-green-100 text-green-800' :
                      row.kind === 'reframed' ? 'bg-blue-100 text-blue-800' :
                      row.kind === 'abstract-only' ? 'bg-amber-100 text-amber-800' :
                      row.kind === 'synthesis-only' ? 'bg-purple-100 text-purple-800' :
                      'bg-gray-100 text-gray-700'
                    }`}>{kindLabel[row.kind] ?? row.kind}</span>
                  </td>
                  <td class="py-2 pr-3 text-gray-800 leading-snug">{row.abstractSentence ?? ''}</td>
                  <td class="py-2 pr-3 text-gray-800 leading-snug">{row.synthesisSentence ?? ''}</td>
                  <td class="py-2 pr-3 text-gray-600 italic whitespace-nowrap">{row.category ?? ''}</td>
                  <td class="py-2 text-gray-600 leading-snug">{row.note ?? ''}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>
    )}

    {(synthesizerPrompt || comparatorPrompt) && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {synthesizerPrompt && (
          <details class="rounded-lg border border-gray-200 bg-gray-50/40">
            <summary class="cursor-pointer select-none px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100/60 rounded-t-lg">
              ▸ Show synthesizer prompt
            </summary>
            <pre class="m-0 px-4 pb-4 pt-2 text-xs text-gray-800 font-mono whitespace-pre-wrap break-words" style="max-height: 600px; overflow-y: auto;">{synthesizerPrompt}</pre>
          </details>
        )}
        {comparatorPrompt && (
          <details class="rounded-lg border border-gray-200 bg-gray-50/40">
            <summary class="cursor-pointer select-none px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100/60 rounded-t-lg">
              ▸ Show comparator prompt
            </summary>
            <pre class="m-0 px-4 pb-4 pt-2 text-xs text-gray-800 font-mono whitespace-pre-wrap break-words" style="max-height: 600px; overflow-y: auto;">{comparatorPrompt}</pre>
          </details>
        )}
      </div>
    )}
  </section>
)}

<style>
  .traceback-claim {
    text-decoration: none;
    border-radius: 3px;
    padding: 1px 3px;
    transition: background-color 0.12s ease;
  }
  .traceback-claim:hover {
    background-color: #fef3c7;
  }
</style>

<script>
  document.querySelectorAll<HTMLAnchorElement>('.traceback-claim').forEach(a => {
    const slug = a.dataset.targetClaim;
    if (!slug) return;
    a.addEventListener('click', (e) => {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent('open-claim', { detail: { slug } }));
    });
  });
</script>
