---
// Backwards-compat redirect: /method → /methodology.
// The page was renamed when the methodology surface gained tabbed sections.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const target = `${base}/methodology/`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <link rel="canonical" href={target} />
  <title>Redirecting to Methodology — eLife Claim Trees</title>
</head>
<body>
  <p>Redirecting to <a href={target}>Methodology</a>…</p>
  <script define:vars={{ target }}>window.location.replace(target);</script>
</body>
</html>
