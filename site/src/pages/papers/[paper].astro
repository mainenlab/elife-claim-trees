---
import Layout from '../../layouts/Layout.astro';
import ClaimTreeNode from '../../components/ClaimTreeNode.astro';
import AbstractAlignment from '../../components/AbstractAlignment.astro';
import ArgumentFromGraph from '../../components/ArgumentFromGraph.astro';
import corpus from '../../data/claims.json';

// Eager-glob all abstract mappings; resolve current paper at runtime.
const abstractMappings = import.meta.glob('../../data/abstract-mapping/*.json', { eager: true }) as Record<string, { default: any }>;
const synthesisFiles = import.meta.glob('../../data/synthesis/*.json', { eager: true }) as Record<string, { default: any }>;

export function getStaticPaths() {
  return corpus.papers.map(p => ({ params: { paper: p.slug } }));
}

const { paper: paperSlug } = Astro.params;
const paperData = corpus.papers.find(p => p.slug === paperSlug)!;

type BadgeInfo = { html: string; description: string };
const badgeConfig: Record<string, BadgeInfo> = {
  gold:              { html: '<span class="badge badge-gold"><span style="color:#fcd34d">●</span> GOLD</span>',              description: 'Deposit reproduces main claims without specialist hardware or institutional software.' },
  silver:            { html: '<span class="badge badge-silver"><span style="color:#cbd5e1">●</span> SILVER</span>',          description: 'Genuine deposit; a documented partial barrier exists but the path to reproduction is clear.' },
  'none-compute':    { html: '<span class="badge badge-compute">NO BADGE <span style="opacity:0.7;font-weight:400">/ compute</span></span>',         description: 'Reproduction requires infrastructure beyond a standard workstation (GPU cluster, HPC, or large downloads with no pre-computed shortcut).' },
  'none-gap':        { html: '<span class="badge badge-gap">NO BADGE <span style="opacity:0.8;font-weight:400">/ deposit gap</span></span>',         description: 'Required data or code is unavailable, hard-coded to local paths, or does not match what the analysis requires.' },
  'none-structural': { html: '<span class="badge badge-structural">NO BADGE <span style="opacity:0.7;font-weight:400">/ structural</span></span>',   description: 'Primary claims require physical apparatus, proprietary materials, or specialist equipment; verification requires atlas inspection rather than analysis re-execution.' },
  pending:           { html: '<span class="badge badge-pending" style="font-style:italic">PENDING</span>',                   description: 'Verification in progress.' },
};

const badge = badgeConfig[(paperData as any).badge ?? 'pending'] ?? badgeConfig.pending;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}/`;

const statusOrder = ['verified', 'unverified:code-error', 'unverified:compute-infeasible', 'unverified', 'unverified:no-data', 'unverified:no-code', 'failed', 'unknown'];

const statusGroups = [
  { key: 'verified', label: 'Verified', color: '#22c55e' },
  { key: 'failed', label: 'Failed', color: '#ef4444' },
  { key: 'unverified:code-error', label: 'Code error', color: '#f97316' },
  { key: 'unverified:compute-infeasible', label: 'Compute-infeasible', color: '#f97316' },
  { key: 'unverified:no-data', label: 'No data', color: '#9ca3af' },
  { key: 'unverified:no-code', label: 'No code', color: '#9ca3af' },
  { key: 'unverified', label: 'Unverified', color: '#9ca3af' },
];

// Hierarchical cascade rendering — default for all papers.
// Headley keeps a paper-specific two-tier split (primary conclusions vs
// additional standalone claims); every other paper renders a single tier.
const isHeadley = paperSlug === 'headley-2026-inhibitory-rhythms';

const claimsBySlug: Record<string, any> = {};
for (const c of paperData.claims) claimsBySlug[c.slug] = c;

const requiredSet = new Set<string>();
for (const c of paperData.claims) {
  for (const r of (c.requires ?? [])) requiredSet.add(r);
}
const rootClaims = paperData.claims.filter(c => !requiredSet.has(c.slug));

// Headley two-tier split: primary conclusions vs additional standalone claims.
// Hardcoded primary IDs for now; generalization later.
const primaryConclusionIds = ['pv-gamma-sst-beta-correspondence', 'ei-lag-sensitivity-firing-rate'];
const primaryRoots = primaryConclusionIds
  .map(id => rootClaims.find(r => r.slug === id))
  .filter(Boolean) as typeof rootClaims;
const additionalRoots = rootClaims
  .filter(r => !primaryConclusionIds.includes(r.slug))
  .sort((a, b) => a.slug.localeCompare(b.slug));

// Default (non-Headley) single-tier roots, alphabetised for stable ordering.
const defaultRoots = [...rootClaims].sort((a, b) => a.slug.localeCompare(b.slug));
const conclusionsHeading = defaultRoots.length === 1 ? 'Conclusion' : 'Conclusions';

// Sorted alphabetical index for the bottom of the cascade page.
const alphaClaims = [...paperData.claims].sort((a, b) => a.slug.localeCompare(b.slug));

// Resolve abstract-to-claims mapping for this paper, if one exists.
const mappingKey = Object.keys(abstractMappings).find(k => k.endsWith(`/${paperSlug}.json`));
const abstractMapping = mappingKey ? abstractMappings[mappingKey].default : null;

// Resolve synthesis (v2) for this paper, if one exists.
const synthesisKey = Object.keys(synthesisFiles).find(k => k.endsWith(`/${paperSlug}.json`));
const synthesisData = synthesisKey ? synthesisFiles[synthesisKey].default : null;
const synthesisV2 = synthesisData?.synthesisV2 ?? null;
---

<Layout title={paperData.title}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <!-- Header -->
    <div class="mb-8">
      <div class="text-xs text-gray-500 mb-2">
        <a href={url('/papers')} class="hover:underline">Papers</a> /
      </div>
      <div class="flex items-start gap-4 mb-3">
        <h1 class="text-xl font-semibold text-gray-900 leading-snug flex-1">{paperData.title}</h1>
        <div class="flex-shrink-0 flex flex-col items-start gap-1" title={badge.description}>
          <span set:html={badge.html} />
          <span class="text-xs text-gray-500 leading-tight max-w-[12rem]">{badge.description}</span>
        </div>
      </div>
      <div class="text-sm text-gray-600 mb-4">
        {paperData.authors.join(', ')}
      </div>
      <div class="flex flex-wrap gap-3 text-xs">
        {paperData.doi && (
          <a href={`https://doi.org/${paperData.doi}`} target="_blank" class="text-blue-600 hover:underline">
            DOI: {paperData.doi} ↗
          </a>
        )}
        {paperData.github && (
          <a href={paperData.github} target="_blank" class="text-gray-600 hover:underline">
            GitHub ↗
          </a>
        )}
      </div>
    </div>

    <!-- Status summary -->
    <div class="mb-8 flex flex-wrap gap-3">
      {statusGroups.filter(g => (paperData.statusCounts[g.key] ?? 0) > 0).map(g => (
        <div class="flex items-center gap-1.5 text-sm">
          <span style={{ width: 10, height: 10, borderRadius: 3, background: g.color, display: 'inline-block' }} />
          <span class="text-gray-700 font-medium">{paperData.statusCounts[g.key]}</span>
          <span class="text-gray-500">{g.label}</span>
        </div>
      ))}
      <div class="ml-auto text-sm text-gray-500">{paperData.claimCount} claims total</div>
    </div>

    {abstractMapping && (
      <AbstractAlignment
        mapping={abstractMapping}
        paperSlug={paperSlug}
        baseUrl={base}
        claimsBySlug={claimsBySlug}
      />
    )}

    {synthesisV2 && (
      <ArgumentFromGraph synthesisV2={synthesisV2} />
    )}

    <!-- Framing line -->
    <p class="text-sm text-gray-500 italic mb-8 leading-relaxed max-w-3xl">
      The root claims of this paper's argument tree. Each conclusion descends into the claims that support it, down to the figure panels and data. Read top-down for the takeaway, or follow the descent to inspect the evidence.
    </p>

    {isHeadley ? (
      <>
        <!-- Section 1: Primary Conclusions -->
        <section class="mb-10">
          <h2 class="text-base font-semibold text-gray-900 uppercase tracking-wide mb-5">
            Primary conclusions
          </h2>
          {primaryRoots.map(root => (
            <ClaimTreeNode
              claim={root}
              depth={0}
              paperSlug={paperSlug}
              baseUrl={base}
              allClaims={claimsBySlug}
              tier="primary"
              foldable={true}
            />
          ))}
        </section>

        <hr class="my-12 border-gray-200" />

        <!-- Section 2: Additional Standalone Claims -->
        <section class="mb-10">
          <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-3">
            Additional standalone claims
          </h2>
          <p class="text-xs text-gray-500 italic mb-6 leading-relaxed max-w-3xl">
            These claims also have no other claim depending on them in the current graph. They may be intermediate results not yet linked to a higher synthesis, or genuinely standalone observations. Surfacing them honestly is part of the claim-graph methodology — the schema reports what the data says, not what the narrative selects.
          </p>
          {additionalRoots.map(root => (
            <ClaimTreeNode
              claim={root}
              depth={0}
              paperSlug={paperSlug}
              baseUrl={base}
              allClaims={claimsBySlug}
              tier="secondary"
              foldable={true}
            />
          ))}
        </section>
      </>
    ) : (
      <section class="mb-10">
        <h2 class="text-base font-semibold text-gray-900 uppercase tracking-wide mb-5">
          {conclusionsHeading}
        </h2>
        {defaultRoots.length === 0 ? (
          <p class="text-xs text-gray-500 italic leading-relaxed max-w-3xl">
            (no root claims identified — graph may be cyclic or all claims have downstream dependencies)
          </p>
        ) : (
          defaultRoots.map(root => (
            <ClaimTreeNode
              claim={root}
              depth={0}
              paperSlug={paperSlug}
              baseUrl={base}
              allClaims={claimsBySlug}
              tier="primary"
              foldable={true}
            />
          ))
        )}
      </section>
    )}

    <!-- Compact alphabetical index -->
    <div class="mt-12 pt-6 border-t border-gray-200">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Claim index</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1 text-xs">
        {alphaClaims.map(c => (
          <li>
            <a
              href={url(`/papers/${paperSlug}/${c.slug}`)}
              class="text-blue-600 hover:underline font-mono"
            >{c.slug}</a>
            {c.panel && <span class="text-gray-400 ml-2">{c.panel}</span>}
          </li>
        ))}
      </ul>
    </div>
  </div>
</Layout>
