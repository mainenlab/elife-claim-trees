---
import Layout from '../../../layouts/Layout.astro';
import corpus from '../../../data/claims.json';
import { STATUS_TAILWIND, EPISTEMIC_TAILWIND, STATUS_LABEL, nodeColor } from '../../../lib/status';

export function getStaticPaths() {
  const paths = [];
  for (const paper of corpus.papers) {
    for (const claim of paper.claims) {
      paths.push({ params: { paper: paper.slug, claim: claim.slug } });
    }
  }
  return paths;
}

const { paper: paperSlug, claim: claimSlug } = Astro.params;
const paperData = corpus.papers.find(p => p.slug === paperSlug)!;
const claimData = paperData.claims.find(c => c.slug === claimSlug)!;

const claimIndex = new Map(paperData.claims.map(c => [c.slug, c]));

const requiresClaims = claimData.requires.map(r => claimIndex.get(r)).filter(Boolean);
const supportsClaims = claimData.supports.map(s => claimIndex.get(s)).filter(Boolean);
// Claims that require this claim (dependents)
const dependentClaims = paperData.claims.filter(c => c.requires.includes(claimSlug));

const color = nodeColor(claimData.status);
---

<Layout title={claimData.slug}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-xs text-gray-500 mb-4">
      <a href="/papers" class="hover:underline">Papers</a> /
      <a href={`/papers/${paperSlug}`} class="hover:underline">{paperSlug}</a> /
    </div>

    <!-- Claim sentence -->
    <div
      class="border-l-4 pl-5 mb-8"
      style={{ borderColor: color }}
    >
      <p class="text-xl font-medium text-gray-900 leading-relaxed">{claimData.claim}</p>
    </div>

    <!-- Badges -->
    <div class="flex flex-wrap gap-2 mb-8">
      <span
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium"
        style={{ background: color + '18', border: `1.5px solid ${color}`, color: '#111' }}
      >
        <span style={{ width: 8, height: 8, borderRadius: 2, background: color, display: 'inline-block' }} />
        {STATUS_LABEL[claimData.status] ?? claimData.status}
      </span>
      <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${EPISTEMIC_TAILWIND[claimData.epistemic] ?? 'bg-gray-100 text-gray-700'}`}>
        {claimData.epistemic} epistemic
      </span>
      {claimData.isAssessment && (
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-50 text-purple-700 border border-purple-200">
          assessment claim
        </span>
      )}
    </div>

    <!-- Meta grid -->
    <div class="grid sm:grid-cols-2 gap-4 mb-8 text-sm">
      {claimData.panel && (
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Panel</div>
          <div class="text-gray-800">{claimData.panel}</div>
        </div>
      )}
      {claimData.analysis && (
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Analysis</div>
          <div class="text-gray-800 font-mono text-xs">{claimData.analysis}</div>
        </div>
      )}
      {claimData.dataset && (
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Dataset</div>
          <a href={claimData.dataset} target="_blank" class="text-blue-600 text-xs hover:underline break-all">{claimData.dataset} ↗</a>
        </div>
      )}
      {claimData.method && (
        <div>
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">Method</div>
          <div class="text-gray-800">{claimData.method}</div>
        </div>
      )}
    </div>

    <!-- Dependencies -->
    {requiresClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Requires (depends on)</h2>
        <div class="space-y-2">
          {requiresClaims.map(r => r && (
            <a href={`/papers/${paperSlug}/${r.slug}`} class="flex items-start gap-2.5 p-3 border border-gray-200 rounded-lg hover:border-gray-400 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(r.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-gray-700 group-hover:text-blue-700">{r.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{r.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {supportsClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Supports</h2>
        <div class="space-y-2">
          {supportsClaims.map(s => s && (
            <a href={`/papers/${paperSlug}/${s.slug}`} class="flex items-start gap-2.5 p-3 border border-green-100 rounded-lg hover:border-green-300 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(s.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-green-700 group-hover:text-green-900">{s.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{s.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {dependentClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Required by</h2>
        <div class="space-y-2">
          {dependentClaims.map(d => (
            <a href={`/papers/${paperSlug}/${d.slug}`} class="flex items-start gap-2.5 p-3 border border-gray-100 rounded-lg hover:border-gray-300 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(d.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-gray-600 group-hover:text-blue-700">{d.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{d.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Notes / reproduction block -->
    {claimData.notes && (
      <div class="mb-8">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-3">Reproduction notes</h2>
        <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-700 leading-relaxed whitespace-pre-wrap font-mono text-xs">
          {claimData.notes}
        </div>
      </div>
    )}

    <div class="border-t border-gray-100 pt-6">
      <a href={`/papers/${paperSlug}`} class="text-sm text-gray-500 hover:text-gray-700">
        ← Back to {paperSlug}
      </a>
    </div>
  </div>
</Layout>
