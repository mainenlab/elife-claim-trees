---
import Layout from '../../../layouts/Layout.astro';
import corpus from '../../../data/claims.json';
import { STATUS_TAILWIND, EPISTEMIC_TAILWIND, STATUS_LABEL, nodeColor } from '../../../lib/status';

export function getStaticPaths() {
  const paths = [];
  for (const paper of corpus.papers) {
    for (const claim of paper.claims) {
      paths.push({ params: { paper: paper.slug, claim: claim.slug } });
    }
  }
  return paths;
}

const { paper: paperSlug, claim: claimSlug } = Astro.params;
const paperData = corpus.papers.find(p => p.slug === paperSlug)!;
const claimData = paperData.claims.find(c => c.slug === claimSlug)!;

const claimIndex = new Map(paperData.claims.map(c => [c.slug, c]));

const requiresClaims = claimData.requires.map(r => claimIndex.get(r)).filter(Boolean);
const supportsClaims = claimData.supports.map(s => claimIndex.get(s)).filter(Boolean);
const dependentClaims = paperData.claims.filter(c => c.requires.includes(claimSlug));

const color = nodeColor(claimData.status);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}/`;

const GITHUB_BASE = 'https://github.com/zmainen/elife-claim-trees/blob/main';

const executionBadge = ({
  'unmodified':   { label: 'Run unmodified', color: '#166534', bg: '#dcfce7' },
  'patched':      { label: 'Run with patch', color: '#92400e', bg: '#fef3c7' },
  'pre-computed': { label: 'Pre-computed outputs', color: '#1e40af', bg: '#dbeafe' },
  'not-executed': { label: 'Not executed', color: '#6b7280', bg: '#f3f4f6' },
} as Record<string, {label:string, color:string, bg:string}>)[claimData.script_execution as string]
  ?? { label: 'Unknown', color: '#6b7280', bg: '#f3f4f6' };

const originalScriptFilename = claimData.original_script
  ? decodeURIComponent(claimData.original_script.split('/').pop() || '')
  : null;
---

<Layout title={claimData.slug}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">

    <!-- Breadcrumb -->
    <div class="text-xs text-gray-500 mb-6">
      <a href={url('/papers')} class="hover:underline">Papers</a> /
      <a href={url(`/papers/${paperSlug}`)} class="hover:underline">{paperSlug}</a> /
      <span class="text-gray-400">{claimData.slug}</span>
    </div>

    <!-- Claim proposition (full width) -->
    <div class="claim-proposition">
      <div class="claim-label">Claim · {claimData.panel}</div>
      <h1>{claimData.claim}</h1>
      <div class="claim-meta">
        <span
          class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium"
          style={{ background: color + '18', border: `1.5px solid ${color}`, color: '#111' }}
        >
          <span style={{ width: 8, height: 8, borderRadius: 2, background: color, display: 'inline-block' }} />
          {STATUS_LABEL[claimData.status] ?? claimData.status}
        </span>
        <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ${EPISTEMIC_TAILWIND[claimData.epistemic] ?? 'bg-gray-100 text-gray-700'}`}>
          {claimData.epistemic} epistemic
        </span>
        {claimData.isAssessment && (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-purple-50 text-purple-700 border border-purple-200">
            assessment claim
          </span>
        )}
      </div>
    </div>

    <!-- Two-column comparison -->
    <div class="comparison-grid">

      <!-- LEFT: Paper -->
      <div class="comparison-col paper-col">
        <div class="col-header">Paper</div>

        {claimData.original_figure && (
          <div class="figure-block">
            <img src={`${base}/${claimData.original_figure}`} alt="Original figure from paper" />
            <div class="figure-source">From eLife · {claimData.panel}</div>
          </div>
        )}

        {claimData.original_script && (
          <div class="script-block">
            <div class="script-label">Analysis script</div>
            <a href={claimData.original_script} target="_blank" class="script-link">
              {originalScriptFilename} <span class="ext-icon">↗</span>
            </a>
            {claimData.script_execution && (
              <div
                class="execution-badge"
                style={{ color: executionBadge.color, background: executionBadge.bg }}
              >
                {executionBadge.label}
              </div>
            )}
            {claimData.script_execution_note && (
              <p class="execution-note">{claimData.script_execution_note}</p>
            )}
          </div>
        )}

        <!-- Dataset / method meta -->
        <div class="meta-block">
          {claimData.dataset && (
            <div class="meta-row">
              <div class="meta-label">Dataset</div>
              <a href={claimData.dataset} target="_blank" class="meta-link">{claimData.dataset} ↗</a>
            </div>
          )}
          {claimData.method && (
            <div class="meta-row">
              <div class="meta-label">Method</div>
              <div class="meta-value">{claimData.method}</div>
            </div>
          )}
          {claimData.analysis && (
            <div class="meta-row">
              <div class="meta-label">Analysis</div>
              <div class="meta-value font-mono text-xs">{claimData.analysis}</div>
            </div>
          )}
        </div>
      </div>

      <!-- RIGHT: Verification -->
      <div class="comparison-col verification-col">
        <div class="col-header verification-header">
          Verification
          <span class="status-chip" style={{ background: color + '18', border: `1.5px solid ${color}`, color: '#111' }}>
            {STATUS_LABEL[claimData.status] ?? claimData.status}
          </span>
        </div>

        {claimData.figure && (
          <div class="figure-block">
            <img src={`${base}/${claimData.figure}`} alt="Reproduced figure" />
            <div class="figure-source">
              Reproduced from deposited data
              {claimData.script && (
                <span> · <a href={`${GITHUB_BASE}/${claimData.script}`} target="_blank" class="source-link">code ↗</a></span>
              )}
            </div>
          </div>
        )}

        {claimData.script && (
          <div class="script-block">
            <div class="script-label">Verification script</div>
            <a href={`${GITHUB_BASE}/${claimData.script}`} target="_blank" class="script-link">
              verify.py <span class="ext-icon">↗</span>
            </a>
            <div class="time-estimates">
              {claimData.time_fast && <span class="time-badge fast">Fast: {claimData.time_fast}</span>}
              {claimData.time_full && <span class="time-badge full">Full: {claimData.time_full}</span>}
            </div>
          </div>
        )}

        {!claimData.figure && !claimData.script && (
          <div class="no-verification">
            <p>No verification script or reproduced figure for this claim.</p>
          </div>
        )}

        {claimData.log_output && (
          <details class="output-log">
            <summary>Full verification output</summary>
            <pre>{claimData.log_output}</pre>
          </details>
        )}
      </div>
    </div>

    <!-- Reproduction notes -->
    {claimData.notes && (
      <div class="mb-8">
        <h2 class="section-heading">Reproduction notes</h2>
        <div class="bg-gray-50 rounded-lg p-4 text-sm text-gray-700 leading-relaxed whitespace-pre-wrap font-mono text-xs border border-gray-200">
          {claimData.notes}
        </div>
      </div>
    )}

    <!-- Dependencies -->
    {requiresClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="section-heading">Requires (depends on)</h2>
        <div class="space-y-2">
          {requiresClaims.map(r => r && (
            <a href={url(`/papers/${paperSlug}/${r.slug}`)} class="flex items-start gap-2.5 p-3 border border-gray-200 rounded-lg hover:border-gray-400 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(r.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-gray-700 group-hover:text-blue-700">{r.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{r.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {supportsClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="section-heading">Supports</h2>
        <div class="space-y-2">
          {supportsClaims.map(s => s && (
            <a href={url(`/papers/${paperSlug}/${s.slug}`)} class="flex items-start gap-2.5 p-3 border border-green-100 rounded-lg hover:border-green-300 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(s.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-green-700 group-hover:text-green-900">{s.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{s.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {dependentClaims.length > 0 && (
      <div class="mb-6">
        <h2 class="section-heading">Required by</h2>
        <div class="space-y-2">
          {dependentClaims.map(d => (
            <a href={url(`/papers/${paperSlug}/${d.slug}`)} class="flex items-start gap-2.5 p-3 border border-gray-100 rounded-lg hover:border-gray-300 no-underline transition-colors group">
              <span style={{ width: 8, height: 8, borderRadius: 2, background: nodeColor(d.status), flexShrink: 0, marginTop: 4 }} />
              <div>
                <div class="text-xs font-medium text-gray-600 group-hover:text-blue-700">{d.slug}</div>
                <div class="text-xs text-gray-500 mt-0.5 line-clamp-2">{d.claim}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="border-t border-gray-100 pt-6">
      <a href={url(`/papers/${paperSlug}`)} class="text-sm text-gray-500 hover:text-gray-700">
        ← Back to {paperSlug}
      </a>
    </div>

  </div>
</Layout>

<style>
  /* Claim proposition */
  .claim-proposition {
    margin: 2rem 0;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 8px;
    border-left: 4px solid #2563eb;
  }
  .claim-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }
  .claim-proposition h1 {
    font-size: 1.15rem;
    font-weight: 600;
    color: #111827;
    margin: 0.5rem 0 1rem;
    line-height: 1.5;
  }
  .claim-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  /* Two-column comparison */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 2rem 0;
  }
  .comparison-col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .col-header {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6b7280;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .verification-header {
    color: #2563eb;
    border-color: #2563eb;
  }
  .status-chip {
    font-size: 0.6rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Figures */
  .figure-block {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .figure-block img {
    width: 100%;
    border-radius: 6px;
    border: 1px solid #e5e7eb;
  }
  .figure-source {
    font-size: 0.7rem;
    color: #9ca3af;
  }
  .source-link {
    color: #9ca3af;
    text-decoration: underline;
  }

  /* Script blocks */
  .script-block {
    background: #f9fafb;
    border-radius: 6px;
    padding: 0.75rem;
    border: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .script-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    font-weight: 700;
    color: #9ca3af;
  }
  .script-link {
    font-family: monospace;
    font-size: 0.8rem;
    color: #2563eb;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    word-break: break-all;
  }
  .script-link:hover { text-decoration: underline; }
  .ext-icon { font-size: 0.7rem; }
  .execution-badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    margin-top: 0.25rem;
    align-self: flex-start;
  }
  .execution-note {
    font-size: 0.72rem;
    color: #6b7280;
    margin: 0;
    font-style: italic;
  }

  /* Time estimates */
  .time-estimates {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }
  .time-badge {
    font-size: 0.65rem;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }
  .time-badge.fast { background: #dcfce7; color: #166534; }
  .time-badge.full { background: #fef9c3; color: #854d0e; }

  /* Meta block */
  .meta-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .meta-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #9ca3af;
  }
  .meta-value {
    font-size: 0.75rem;
    color: #374151;
  }
  .meta-link {
    font-size: 0.7rem;
    color: #2563eb;
    text-decoration: none;
    word-break: break-all;
  }
  .meta-link:hover { text-decoration: underline; }

  /* Log output */
  .output-log {
    margin-top: 0.5rem;
  }
  .output-log summary {
    font-size: 0.75rem;
    color: #6b7280;
    cursor: pointer;
    user-select: none;
  }
  .output-log pre {
    font-size: 0.65rem;
    background: #111827;
    color: #d1d5db;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    max-height: 300px;
    overflow-y: auto;
    margin-top: 0.5rem;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* No verification placeholder */
  .no-verification {
    background: #f9fafb;
    border: 1px dashed #e5e7eb;
    border-radius: 6px;
    padding: 1rem;
  }
  .no-verification p {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 0;
    text-align: center;
  }

  /* Section headings */
  .section-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .comparison-grid { grid-template-columns: 1fr; }
  }
</style>
