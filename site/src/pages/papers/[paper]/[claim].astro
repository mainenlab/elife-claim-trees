---
import corpus from '../../../data/claims.json';

export function getStaticPaths() {
  const paths = [];
  for (const paper of corpus.papers) {
    for (const claim of paper.claims) {
      paths.push({ params: { paper: paper.slug, claim: claim.slug } });
    }
  }
  return paths;
}

const { paper, claim } = Astro.params;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const target = `${base}/papers/${paper}/?claim=${claim}`;
return Astro.redirect(target, 301);
