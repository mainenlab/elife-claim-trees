---
import Layout from '../layouts/Layout.astro';
import ReviewTab from '../components/ReviewTab.tsx';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}/`;
---

<Layout title="Extract & Review">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <h1 class="text-3xl font-semibold text-gray-900 dark:text-gray-100 tracking-tight mb-3">Extract & Review</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6">
      Upload a manuscript. The system extracts structured claims, then you can review them with AI reviewers.
    </p>

    <!-- Settings (collapsed) -->
    <details id="settings" class="mb-6">
      <summary class="text-xs font-medium text-gray-400 dark:text-gray-500 cursor-pointer hover:text-gray-600 dark:hover:text-gray-300 select-none">
        Settings
      </summary>
      <div class="mt-3 space-y-3 p-4 border border-gray-200 dark:border-gray-700 rounded-lg bg-gray-50 dark:bg-gray-800/30">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Provider</label>
            <select id="provider"
              class="w-full px-3 py-1.5 border border-gray-200 dark:border-gray-700 rounded-lg text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <option value="anthropic">Anthropic</option>
              <option value="openai">OpenAI</option>
              <option value="google">Google (Gemini)</option>
              <option value="openrouter">OpenRouter</option>
              <option value="vertex">Vertex AI (demo token)</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-500 mb-1">Model</label>
            <select id="model-select"
              class="w-full px-3 py-1.5 border border-gray-200 dark:border-gray-700 rounded-lg text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
              <option value="claude-sonnet-4-6">Claude Sonnet 4</option>
              <option value="claude-opus-4-6">Claude Opus 4</option>
            </select>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div id="api-key-group">
            <label class="block text-xs font-medium text-gray-500 mb-1">API key</label>
            <input type="password" id="api-key" placeholder="sk-ant-..."
              class="w-full px-3 py-1.5 border border-gray-200 dark:border-gray-700 rounded-lg text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" />
          </div>
          <div id="demo-token-group" class="hidden">
            <label class="block text-xs font-medium text-gray-500 mb-1">Demo token</label>
            <input type="password" id="demo-token" placeholder="demo token"
              class="w-full px-3 py-1.5 border border-gray-200 dark:border-gray-700 rounded-lg text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" />
          </div>
        </div>
      </div>
    </details>

    <!-- Upload -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Manuscript (PDF or DOCX)</label>
      <input type="file" id="file-upload" accept=".pdf,.docx,.doc"
        class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg text-sm bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100 file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-gray-100 dark:file:bg-gray-700 file:text-gray-700 dark:file:text-gray-300 file:cursor-pointer" />
    </div>

    <button id="extract-btn"
      class="px-4 py-2 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 text-sm font-medium rounded-lg hover:bg-gray-700 dark:hover:bg-gray-300 transition-colors cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed">
      Extract claims
    </button>

    <!-- Console -->
    <div id="console" class="hidden mt-6">
      <div id="console-log" class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-gray-50 dark:bg-gray-800/50 max-h-48 overflow-y-auto space-y-0.5 text-sm font-mono"></div>
      <div id="stale-warning" class="hidden mt-2 p-2 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded text-xs text-yellow-700 dark:text-yellow-300">
        No response for 30 seconds — the server may be processing a large request or the connection may have dropped.
      </div>
    </div>

    <!-- Error -->
    <div id="error" class="hidden mt-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-sm text-red-700 dark:text-red-300"></div>

    <!-- Results -->
    <div id="results" class="hidden mt-8">
      <div id="result-stats" class="grid grid-cols-3 gap-4 mb-4"></div>
      <div id="claim-list" class="space-y-2 mb-4"></div>
      <div id="downloads" class="mb-6"></div>

      <!-- Review section (appears after extraction) -->
      <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">Review</h2>
        <div id="review-mount"></div>
      </div>
    </div>

  </div>

  <script is:inline>
    const API_URL = window.location.hostname === 'localhost'
      ? 'http://localhost:8081'
      : 'https://console.haak.world/elife-extract';

    const btn = document.getElementById('extract-btn');
    const consoleDiv = document.getElementById('console');
    const consoleLog = document.getElementById('console-log');
    const resultsDiv = document.getElementById('results');
    const errorDiv = document.getElementById('error');

    // Provider → model mapping
    const providerModels = {
      anthropic: [{id: 'claude-sonnet-4-6', name: 'Claude Sonnet 4'}, {id: 'claude-opus-4-6', name: 'Claude Opus 4'}],
      openai: [{id: 'gpt-4o', name: 'GPT-4o'}, {id: 'gpt-4o-mini', name: 'GPT-4o Mini'}, {id: 'o3', name: 'o3'}],
      google: [{id: 'gemini-2.5-pro', name: 'Gemini 2.5 Pro'}, {id: 'gemini-2.5-flash', name: 'Gemini 2.5 Flash'}],
      openrouter: [{id: 'anthropic/claude-sonnet-4', name: 'Claude Sonnet 4'}, {id: 'openai/gpt-4o', name: 'GPT-4o'}, {id: 'google/gemini-2.5-pro', name: 'Gemini 2.5 Pro'}],
      vertex: [{id: 'claude-sonnet-4-6', name: 'Claude Sonnet 4 (Vertex)'}, {id: 'claude-opus-4-6', name: 'Claude Opus 4 (Vertex)'}],
    };

    const keyPlaceholders = {
      anthropic: 'sk-ant-...',
      openai: 'sk-...',
      google: 'AIza...',
      openrouter: 'sk-or-...',
      vertex: '',
    };

    const providerSelect = document.getElementById('provider');
    const modelSelect = document.getElementById('model-select');
    const apiKeyGroup = document.getElementById('api-key-group');
    const demoTokenGroup = document.getElementById('demo-token-group');
    const apiKeyInput = document.getElementById('api-key');

    providerSelect.addEventListener('change', () => {
      const prov = providerSelect.value;
      // Update model dropdown
      const models = providerModels[prov] || [];
      modelSelect.innerHTML = models.map(m => `<option value="${m.id}">${m.name}</option>`).join('');
      // Toggle key vs token
      if (prov === 'vertex') {
        apiKeyGroup.classList.add('hidden');
        demoTokenGroup.classList.remove('hidden');
      } else {
        apiKeyGroup.classList.remove('hidden');
        demoTokenGroup.classList.add('hidden');
        apiKeyInput.placeholder = keyPlaceholders[prov] || 'API key';
      }
    });

    let currentDetails = null;
    let currentStep = null;
    let lastEventTime = Date.now();
    let staleTimer = null;

    function startStaleDetection() {
      lastEventTime = Date.now();
      document.getElementById('stale-warning').classList.add('hidden');
      if (staleTimer) clearInterval(staleTimer);
      staleTimer = setInterval(() => {
        if (Date.now() - lastEventTime > 30000) {
          document.getElementById('stale-warning').classList.remove('hidden');
        }
      }, 5000);
    }

    function stopStaleDetection() {
      if (staleTimer) { clearInterval(staleTimer); staleTimer = null; }
      document.getElementById('stale-warning').classList.add('hidden');
    }

    function onEvent() {
      lastEventTime = Date.now();
      document.getElementById('stale-warning').classList.add('hidden');
    }

    function log(msg, color, step) {
      const isStreamToken = msg.startsWith('  ');
      if (isStreamToken && currentDetails) {
        // Append streaming line to current foldable section
        const line = document.createElement('div');
        line.className = 'text-[11px] text-gray-400 dark:text-gray-500 font-mono';
        line.textContent = msg;
        currentDetails.querySelector('.stream-lines').appendChild(line);
        // Update the summary with token count
        const match = msg.match(/\[(\d+) tokens\]/);
        if (match) {
          currentDetails.querySelector('.token-count').textContent = ` (${match[1]} tokens)`;
        }
        consoleLog.scrollTop = consoleLog.scrollHeight;
        return;
      }

      // New step — close previous details if any
      if (step && step !== currentStep) {
        currentStep = step;
        currentDetails = document.createElement('details');
        currentDetails.className = 'mb-1';
        const summary = document.createElement('summary');
        summary.className = `cursor-pointer text-sm ${color || 'text-gray-500'}`;
        summary.innerHTML = `${msg}<span class="token-count text-xs text-gray-400 ml-1"></span>`;
        currentDetails.appendChild(summary);
        const streamLines = document.createElement('div');
        streamLines.className = 'stream-lines ml-4 mt-1 max-h-32 overflow-y-auto';
        currentDetails.appendChild(streamLines);
        consoleLog.appendChild(currentDetails);
      } else {
        // Non-streaming, non-step message (like "complete" lines)
        const el = document.createElement('div');
        el.className = `text-sm ${color || 'text-gray-500 dark:text-gray-400'}`;
        el.textContent = msg;
        consoleLog.appendChild(el);
        currentDetails = null;
      }
      consoleLog.scrollTop = consoleLog.scrollHeight;
    }

    function showError(msg) {
      errorDiv.textContent = msg;
      errorDiv.classList.remove('hidden');
    }

    btn.addEventListener('click', async () => {
      const fileEl = document.getElementById('file-upload');
      const file = fileEl?.files?.[0];
      const apiKey = document.getElementById('api-key').value.trim();
      const demoToken = document.getElementById('demo-token').value.trim();
      const selectedProvider = document.getElementById('provider').value;
      const selectedModel = document.getElementById('model-select').value;

      if (!file) return showError('Please select a file.');
      if (!apiKey && !demoToken) {
        document.getElementById('settings').open = true;
        return showError('Enter an API key or demo token in Settings.');
      }

      btn.disabled = true;
      btn.textContent = 'Extracting...';
      consoleDiv.classList.remove('hidden');
      consoleLog.innerHTML = '';
      resultsDiv.classList.add('hidden');
      errorDiv.classList.add('hidden');
      startStaleDetection();

      try {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('api_key', apiKey);
        formData.append('demo_token', demoToken);
        formData.append('provider', selectedProvider);
        formData.append('model_extract', selectedModel);
        formData.append('model_reconcile', selectedModel);

        const response = await fetch(API_URL + '/extract-file', {
          method: 'POST',
          body: formData,
        });

        if (!response.ok) throw new Error('Server error: ' + response.status);

        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            try {
              const event = JSON.parse(line.slice(6));
              const colors = {
                prepare: 'text-gray-500 dark:text-gray-400',
                extract: 'text-amber-700 dark:text-amber-400',
                reconcile: 'text-blue-700 dark:text-blue-400',
                review: 'text-purple-700 dark:text-purple-400',
                done: 'text-green-700 dark:text-green-400',
                error: 'text-red-600 dark:text-red-400',
              };
              onEvent();
              if (event.step === 'heartbeat') continue;  // heartbeat — reset timer but don't display
              if (event.message) log(event.message, colors[event.step], event.step);
              if (event.step === 'done' && event.article) renderResults(event.article, apiKey, demoToken);
              if (event.step === 'error') showError(event.message);
            } catch {}
          }
        }
      } catch (e) {
        showError(e.message);
      } finally {
        btn.disabled = false;
        btn.textContent = 'Extract claims';
        stopStaleDetection();
      }
    });

    const roleBadgeColor = {
      hypothesis: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300',
      prediction: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300',
      empirical: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300',
      control: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
      scope: 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300',
      methodological: 'bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-400',
      synthesis: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300',
      interpretation: 'bg-pink-100 text-pink-800 dark:bg-pink-900/30 dark:text-pink-300',
      'literature-context': 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300',
    };

    const roleTooltips = {
      hypothesis: 'The paper\'s central bet — often implicit, not stated directly in the prose',
      prediction: 'A testable consequence deduced from a hypothesis',
      empirical: 'A measured or computed result, grounded in a figure panel',
      control: 'An empirical result whose function is to rule out an alternative explanation',
      scope: 'A boundary condition on other claims ("all results come from...")',
      methodological: 'A capability or analytical decision of the apparatus',
      synthesis: 'Integrates multiple empirical results into one higher-order statement',
      interpretation: 'Reframes results through a theoretical lens — maps to broader theory',
      'literature-context': 'A cited prior result the paper depends on but did not produce',
    };

    const edgeTooltips = {
      'cito:supports': 'Provides factual or intellectual support',
      'cito:extends': 'Builds on facts, ideas, or understandings',
      'cito:qualifies': 'Places conditions upon',
      'cito:disagreesWith': 'Dissociates with — results that separate variables',
      'cito:usesMethodIn': 'Uses a method from this claim',
      'cito:citesAsSourceDocument': 'Derived from this claim',
      'claimrel:requires': 'Logically depends on this claim as a prerequisite',
      'claimrel:tests': 'Submits this claim to empirical test',
      'claimrel:entails': 'Logically entails this claim (deductive)',
      'claimrel:interprets': 'Offers a theoretical reading of this claim',
      'claimrel:scopes': 'Delimits the domain of applicability',
      'claimrel:rulesOut': 'Eliminates this claim as a viable hypothesis',
      'claimrel:replicates': 'Empirically replicates this finding',
      'claimrel:contradicts': 'Presents findings incompatible with this claim',
    };

    function edgeLabel(relType) {
      return relType.split(':').pop().replace(/([A-Z])/g, ' $1').trim().toLowerCase();
    }

    // Group claims by role in a meaningful order
    const roleOrder = ['hypothesis', 'prediction', 'empirical', 'control', 'scope', 'methodological', 'synthesis', 'interpretation', 'literature-context'];

    function renderResults(article, apiKey, demoToken) {
      resultsDiv.classList.remove('hidden');
      const claims = article.children || [];
      const nRels = claims.reduce((s, c) => s + (c.relations || []).length, 0);
      const claimMap = {};
      claims.forEach(c => { claimMap[c.identifier] = c; });

      document.getElementById('result-stats').innerHTML = `
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4">
          <div class="text-2xl font-semibold text-gray-900 dark:text-gray-100">${claims.length}</div>
          <div class="text-xs text-gray-500 mt-1">claims</div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4">
          <div class="text-2xl font-semibold text-gray-900 dark:text-gray-100">${nRels}</div>
          <div class="text-xs text-gray-500 mt-1">relations</div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-4">
          <div class="text-2xl font-semibold text-gray-900 dark:text-gray-100">${new Set(claims.map(c => c.role)).size}</div>
          <div class="text-xs text-gray-500 mt-1">roles</div>
        </div>
      `;

      // Group claims by role
      const grouped = {};
      claims.forEach(c => {
        const r = c.role || 'other';
        if (!grouped[r]) grouped[r] = [];
        grouped[r].push(c);
      });

      let html = '';
      for (const role of roleOrder) {
        const group = grouped[role];
        if (!group || group.length === 0) continue;
        const badge = roleBadgeColor[role] || 'bg-gray-100 text-gray-800';
        const tip = roleTooltips[role] || '';

        html += `<div class="mb-6">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-semibold px-2 py-0.5 rounded ${badge} cursor-help" title="${tip}">${role}</span>
            <span class="text-xs text-gray-400">${group.length}</span>
          </div>`;

        for (const c of group) {
          const text = (c.children || []).map(ch => ch.value || '').join(' ');
          const rels = c.relations || [];
          const panelHtml = c.panel ? `<span class="text-[10px] text-gray-400 ml-1">${c.panel.join(', ')}</span>` : '';

          let relsHtml = '';
          if (rels.length > 0) {
            relsHtml = '<div class="mt-1.5 flex flex-wrap gap-1">';
            for (const r of rels) {
              const label = edgeLabel(r.relationType);
              const tip = edgeTooltips[r.relationType] || r.relationType;
              const targetClaim = claimMap[r.xref];
              const targetText = targetClaim
                ? (targetClaim.children || []).map(ch => ch.value || '').join(' ').slice(0, 60)
                : r.xref;
              relsHtml += `<span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 cursor-help" title="${tip}: ${targetText}...">${label} → ${r.xref.slice(0, 25)}</span>`;
            }
            relsHtml += '</div>';
          }

          html += `<div class="border border-gray-100 dark:border-gray-800 rounded-lg p-2.5 mb-1.5">
            <div class="text-sm text-gray-700 dark:text-gray-300">${text}${panelHtml}</div>
            ${relsHtml}
          </div>`;
        }
        html += '</div>';
      }

      document.getElementById('claim-list').innerHTML = html;

      const blob = new Blob([JSON.stringify(article, null, 2)], { type: 'application/json' });
      document.getElementById('downloads').innerHTML = `
        <a href="${URL.createObjectURL(blob)}" download="${article.identifier}.oxa.json"
           class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 no-underline">
          Download OXA JSON
        </a>
      `;

      // Mount ReviewTab with the extracted claims
      window.__mountReview(claims, article.metadata?.title || article.identifier || '', apiKey, demoToken);
    }
  </script>
</Layout>

<script>
  // Mount ReviewTab React component after extraction
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import ReviewTab from '../components/ReviewTab.tsx';

  let reviewRoot: any = null;

  (window as any).__mountReview = (claims: any[], title: string, apiKey: string, demoToken: string) => {
    const mount = document.getElementById('review-mount');
    if (!mount) return;
    if (!reviewRoot) {
      reviewRoot = createRoot(mount);
    }
    reviewRoot.render(createElement(ReviewTab, { claims, paperTitle: title, abstract: '', initialApiKey: apiKey, initialDemoToken: demoToken }));
  };
</script>
