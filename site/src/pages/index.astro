---
import Layout from '../layouts/Layout.astro';
import corpus from '../data/claims.json';

const { papers, totalClaims } = corpus;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const url = (path: string) => `${base}${path}/`;

const allClaims = papers.flatMap(p => p.claims);
const verifiedCount = allClaims.filter(c => c.status.startsWith('verified')).length;
---

<Layout title="eLife Claim Trees">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">

    <!-- Hero -->
    <div class="mb-16">
      <h1 class="text-4xl font-semibold text-gray-900 tracking-tight mb-3">eLife Claim Trees</h1>
      <p class="text-xl text-gray-500 mb-6">Panel-level claim graphs for reproducibility</p>
      <div class="max-w-2xl space-y-4 text-gray-700 leading-relaxed">
        <p>
          Science is organized around stories. A paper is a narrative artifact designed to convince a human reader.
          AI is a different reader — it needs structure it can reason over, verify, and connect to other structure.
          This project extracts the claim structure of {papers.length} eLife neuroscience papers, links each claim to data and code,
          and records what happened when we ran the analyses.
        </p>
        <p>
          Each paper becomes a directed acyclic graph: claims as nodes, dependencies as edges.
          Invalidity propagates downstream. Independent claims stand alone.
        </p>
      </div>
      <div class="mt-6 flex gap-3 flex-wrap">
        <a href={url('/papers')} class="inline-flex items-center gap-1.5 px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-700 no-underline">
          Browse papers →
        </a>
        <a href={url('/methodology')} class="inline-flex items-center gap-1.5 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 no-underline">
          Read methodology
        </a>
        <a href="https://github.com/zmainen/elife-claim-trees" class="inline-flex items-center gap-1.5 px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 no-underline" target="_blank">
          GitHub ↗
        </a>
      </div>
    </div>

    <!-- Corpus stats -->
    <div class="mb-16">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-5">Corpus</h2>
      <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="bg-gray-50 rounded-xl p-5">
          <div class="text-3xl font-semibold text-gray-900">{papers.length}</div>
          <div class="text-sm text-gray-500 mt-1">papers</div>
        </div>
        <div class="bg-gray-50 rounded-xl p-5">
          <div class="text-3xl font-semibold text-gray-900">{totalClaims}</div>
          <div class="text-sm text-gray-500 mt-1">claims</div>
        </div>
        <div class="bg-green-50 rounded-xl p-5">
          <div class="text-3xl font-semibold text-green-700">{verifiedCount}</div>
          <div class="text-sm text-gray-500 mt-1">verified by code</div>
        </div>
      </div>
    </div>

    <!-- Resources -->
    <div class="mb-16">
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-5">Resources</h2>
      <div class="space-y-3">
        <a href="/elife-claim-trees/haak-overview.pdf" class="flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-gray-400 hover:shadow-sm transition-all no-underline group" target="_blank">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600 font-semibold text-xs">PDF</div>
          <div>
            <div class="text-sm font-medium text-gray-900 group-hover:text-blue-700 transition-colors">HAAK Platform Overview</div>
            <div class="text-xs text-gray-500">Institutional intelligence architecture</div>
          </div>
        </a>
        <a href="/elife-claim-trees/elife-feedback.pdf" class="flex items-center gap-3 p-4 border border-gray-200 rounded-xl hover:border-gray-400 hover:shadow-sm transition-all no-underline group" target="_blank">
          <div class="flex-shrink-0 w-8 h-8 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600 font-semibold text-xs">PDF</div>
          <div>
            <div class="text-sm font-medium text-gray-900 group-hover:text-blue-700 transition-colors">Technical Report (eLife)</div>
            <div class="text-xs text-gray-500">Claim graph method and findings for eLife corpus</div>
          </div>
        </a>
      </div>
    </div>

    <!-- Papers grid -->
    <div>
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-widest mb-5">Papers</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {papers.map(p => {
          const v = p.claims.filter((c: any) => c.status.startsWith('verified')).length;
          const allV = v === p.claimCount && p.claimCount > 0;
          return (
            <a href={url(`/papers/${p.slug}`)} class="block border border-gray-200 rounded-xl p-5 hover:border-gray-400 hover:shadow-sm transition-all no-underline group">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="text-sm font-medium text-gray-900 leading-snug group-hover:text-blue-700 transition-colors">{p.title}</h3>
                {allV && (
                  <span class="flex-shrink-0 text-[10px] font-semibold text-green-800 bg-green-50 border border-green-200 px-1.5 py-0.5 rounded whitespace-nowrap">✓</span>
                )}
              </div>
              <div class="text-xs text-gray-500 mb-3">
                {p.authors.join(', ')} · {(p as any).journal}
                {(p as any).stage && (p as any).stage !== 'published' && (
                  <span class="italic"> · {{preprint:'preprint',revision:'under review',draft:'draft'}[(p as any).stage]}</span>
                )}
              </div>
              <div class="text-xs text-gray-500">
                {p.claimCount} claims
              </div>
            </a>
          );
        })}
      </div>
    </div>

  </div>
</Layout>
