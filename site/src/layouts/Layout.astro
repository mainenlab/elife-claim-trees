---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Panel-level claim graphs for reproducibility — eLife Claim Trees' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — eLife Claim Trees</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body class="min-h-screen bg-white">
  <nav class="border-b border-gray-100 bg-white sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 h-12 flex items-center gap-6">
      <a href="/" class="font-semibold text-gray-900 no-underline hover:text-gray-700 text-sm">eLife Claim Trees</a>
      <a href="/papers" class="text-sm text-gray-500 no-underline hover:text-gray-700">Papers</a>
      <a href="/method" class="text-sm text-gray-500 no-underline hover:text-gray-700">Method</a>
      <a href="/findings" class="text-sm text-gray-500 no-underline hover:text-gray-700">Findings</a>
    </div>
  </nav>
  <main>
    <slot />
  </main>
</body>
</html>
